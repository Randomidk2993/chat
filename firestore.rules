rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for search + DM avatars).
    // Only the owner can write their own document.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Messages ───────────────────────────────────────────────────────────
    // Any signed-in user can read (covers global chat + DMs).
    // Only the actual sender can create a message (no update / delete).
    match /messages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.senderId;
    }

    // ── DM Chats ───────────────────────────────────────────────────────────
    // Only participants can read or write the chat metadata document.
    match /chats/{chatId} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
    }

  }
}
